# Django core
SECRET_KEY=
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend URL (用於 email 中的連結，例如 password reset、email verification)
FRONTEND_URL=http://localhost:5173

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@localhost

# Auth
LOGIN_THROTTLE_RATE=5/min

# Cache / Channels
REDIS_HOST=redis

# Database
DB_NAME=django_channel
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
